<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Shop | Venture Creations</title>
  <link rel="stylesheet" href="/css/styles.css">
  <script src="/scripts/home.js" defer></script>

</head>
<body>
  <%- include('partials/header2') %>

  <main class="container">
    <h1 class="page-title">Our Collection</h1>

    <div class="product-grid">
        <% products.forEach(product => { %>
            <div class="product-card">
                <img src="<%= product.images[0] %>" alt="<%= product.name %>">
                <h2><%= product.name %></h2>
                <div class="product-info">
                    <p class="price">$<%= product.price.toFixed(2) %></p>
                    <a href="/shop/<%= product._id %>" class="btn">View Shirt</a>
                </div>
            </div>
        <% }) %>
    </div>
  </main>

  <% if (totalPages > 1) { %>
    <div class="pagination">
      <% if (currentPage > 1) { %>
        <a href="/shop?page=<%= currentPage - 1 %>" class="btn">← Prev</a>
      <% } %>
      <span>Page <%= currentPage %> of <%= totalPages %></span>
      <% if (currentPage < totalPages) { %>
        <a href="/shop?page=<%= currentPage + 1 %>" class="btn">Next →</a>
      <% } %>
    </div>
  <% } %>

  <%- include('partials/footer') %>
</body>
</html>
